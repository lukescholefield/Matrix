#!/bin/bash

SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.swift')

if [ -z "$SWIFT_FILES" ]; then
  exit 0
fi

if ! command -v swift-format &> /dev/null; then
  echo "warning: swift-format not found, skipping format check"
  exit 0
fi

UNFORMATTED=""
for file in $SWIFT_FILES; do
  if ! swift-format lint "$file" > /dev/null 2>&1; then
    UNFORMATTED="$UNFORMATTED\n  $file"
  fi
done

if [ -n "$UNFORMATTED" ]; then
  echo "The following files have formatting issues:"
  echo -e "$UNFORMATTED"
  echo ""
  echo "Run 'swift format format --in-place --recursive Sources/ Tests/' to fix."
  exit 1
fi
